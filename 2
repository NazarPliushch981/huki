using System;
using System.Diagnostics;
using System.Drawing;
using System.Runtime.InteropServices;
using System.Windows.Forms;

namespace MouseRun
{
    public partial class Form1 : Form
    {
        IntPtr hook = IntPtr.Zero;

        Random r = new Random();

        public Form1()
        {
            InitializeComponent();
        }

        private LowLevelMouseProc proc;

        private void Form1_Load(object sender, EventArgs e)
        {
            proc = HookCallback;

            hook = SetHook(proc);
        }

        delegate IntPtr LowLevelMouseProc(
            int nCode,
            IntPtr wParam,
            IntPtr lParam
        );

        const int WM_LBUTTONDOWN = 0x0201;

        IntPtr HookCallback(
            int nCode,
            IntPtr wParam,
            IntPtr lParam)
        {
            if (nCode >= 0 &&
                wParam == (IntPtr)WM_LBUTTONDOWN)
            {
                MSLLHOOKSTRUCT data =
                    (MSLLHOOKSTRUCT)Marshal.PtrToStructure(
                        lParam,
                        typeof(MSLLHOOKSTRUCT));

                Point p = new Point(data.pt.x, data.pt.y);

                Rectangle rect =
                    button1.RectangleToScreen(
                        button1.ClientRectangle);

                if (rect.Contains(p))
                {
                    int x = r.Next(0, this.Width - button1.Width);
                    int y = r.Next(0, this.Height - button1.Height);

                    button1.Location = new Point(x, y);
                }
            }

            return CallNextHookEx(hook,
                nCode,
                wParam,
                lParam);
        }

        private IntPtr SetHook(LowLevelMouseProc p)
        {
            using (Process cur = Process.GetCurrentProcess())
            using (ProcessModule m = cur.MainModule)
            {
                return SetWindowsHookEx(
                    14,
                    p,
                    GetModuleHandle(m.ModuleName),
                    0);
            }
        }

        [StructLayout(LayoutKind.Sequential)]
        public struct POINT
        {
            public int x;
            public int y;
        }

        [StructLayout(LayoutKind.Sequential)]
        public struct MSLLHOOKSTRUCT
        {
            public POINT pt;
            public int mouseData;
            public int flags;
            public int time;
            public IntPtr dwExtraInfo;
        }

        [DllImport("user32.dll")]
        static extern IntPtr SetWindowsHookEx(
            int idHook,
            LowLevelMouseProc lpfn,
            IntPtr hMod,
            uint dwThreadId
        );

        [DllImport("user32.dll")]
        static extern bool UnhookWindowsHookEx(IntPtr hhk);

        [DllImport("user32.dll")]
        static extern IntPtr CallNextHookEx(
            IntPtr hhk,
            int nCode,
            IntPtr wParam,
            IntPtr lParam
        );

        [DllImport("kernel32.dll")]
        static extern IntPtr GetModuleHandle(string lpModuleName);
    }
}
